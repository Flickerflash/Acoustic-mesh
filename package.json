{
  "name": "acoustic-mesh",
  "version": "1.0.0",
  "private": false,
  "description": "Production-grade WebRTC multi-device acoustic mesh with WebSocket signaling, sensor pipelines, and phi-harmonic modal analysis",
  "workspaces": ["apps/*", "services/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"node services/signaling/index.js\" \"npm run dev --workspace apps/web\"",
    "build": "npm run build --workspaces",
    "start": "node services/signaling/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "keywords": ["webrtc", "websocket", "acoustic", "mesh-network", "signaling", "phi-harmonic"],
  "author": "Ndr \"Ender\" Hensel <https://github.com/Flickerflash>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Flickerflash/Acoustic-mesh.git"
  }
}
